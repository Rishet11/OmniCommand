{
  "name": "omx-cmd",
  "version": "1.0.3",
  "description": "The terminal tool for every format. Natural language file conversion.",
  "main": "dist/lib.js",
  "exports": {
    ".": "./dist/lib.js",
    "./cli": "./dist/index.js",
    "./mcp": "./dist/mcp.js"
  },
  "type": "module",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "omx": "dist/index.js"
  },
  "engines": {
    "node": ">=20.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rishet11/OmniCommand.git"
  },
  "homepage": "https://github.com/Rishet11/OmniCommand#readme",
  "bugs": {
    "url": "https://github.com/Rishet11/OmniCommand/issues"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "dev": "tsc -w",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "cp ../README.md . && cp ../LICENSE . && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ffmpeg-static": "5.2.0",
    "ora": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.1.392",
    "sharp": "^0.33.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.4.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "cli",
    "convert",
    "compress",
    "ffmpeg",
    "sharp",
    "pandoc",
    "file-conversion",
    "pdf",
    "video",
    "image",
    "natural-language",
    "mcp",
    "document",
    "offline",
    "ocr",
    "markdown",
    "resize",
    "trim"
  ],
  "author": "Rishet Mehra",
  "license": "MIT"
}
